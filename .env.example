# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                         # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_hr_db

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                       # local | s3
LOCAL_UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=ai-hr-resumes
AWS_REGION=us-east-1

# ── AI / LLM ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic                      # anthropic | openai
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=claude-sonnet-4-20250514          # or gpt-4o

# ── NLP Models ───────────────────────────────────────────────────────────────
SPACY_MODEL=en_core_web_sm
EMBEDDING_MODEL=all-MiniLM-L6-v2
SPACY_TEXT_CAP=100000                       # max chars fed to spaCy per document

# ── Scoring Weights (must sum to 1.0) ────────────────────────────────────────
WEIGHT_RESUME=0.30
WEIGHT_MATCH=0.30
WEIGHT_INTERVIEW=0.40

# ── Interview Settings ────────────────────────────────────────────────────────
MAX_INTERVIEW_QUESTIONS=5                   # number of questions per session
LLM_MAX_TOKENS=1024                         # max tokens per LLM response
ANSWER_MAX_LENGTH=2000                      # max candidate answer length (chars)

# ── Semantic Matching ─────────────────────────────────────────────────────────
SKILL_MATCH_THRESHOLD=0.75                  # cosine similarity threshold for skill match
SKILL_SCORE_WEIGHT=0.70                     # blend: skill similarity contribution
DOC_SCORE_WEIGHT=0.30                       # blend: document-level similarity contribution

# ── Rate Limiting ─────────────────────────────────────────────────────────────
UPLOAD_RATE_LIMIT=5/minute
LOGIN_RATE_LIMIT=10/minute

# ── File Validation ──────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=5
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
